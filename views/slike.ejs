<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Galerija slika - Dinamički generirana">
    <title>Galerija</title>
    <link rel="stylesheet" href="/style_slike.css">
</head>
<body>

<header>
    <h1>Galerija slika</h1>
    <nav aria-label="Glavna navigacija">
        <ul class="nav-menu">
            <li><a href="/">Početna</a></li>
            <li><a href="/grafikon">Grafikon</a></li>
            <li><a href="/slike">Galerija</a></li>
        </ul>
    </nav>
</header>

<main>
    <section class="galerija"> 
        <h2 style="text-align:center;">Dinamička galerija slika (EJS)</h2>

        <div class="img-gallery-magnific">
            
            <% for(let i = 1; i <= brojSlika; i++) { %>
                
                <figure class="magnific-img">
                    <a href="#img<%= i %>">
                        <img src="https://picsum.photos/300/200?random=<%= i %>" alt="Slika <%= i %>" loading="lazy">
                    </a>
                    <figcaption>Slika <%= i %></figcaption>
                </figure>

                <div id="img<%= i %>" class="lightbox">
                    <a href="#" class="close">&times;</a>
                    <img src="https://picsum.photos/900/600?random=<%= i %>" alt="Velika <%= i %>">
                </div>

            <% } %>

        </div>
    </section>
</main>

</body>
</html>